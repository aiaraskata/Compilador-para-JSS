class Ponto {
    int x;
    int y;
    Ponto constructor(int x, int y) {
        this.x = x;
        this.y = y;
    }
    int soma() {
        return this.x + this.y;
    }
}
function void main() {
    let int value;
    let int numero;
    let int a, b, c;
    const Ponto ponto = new Ponto(10,20);
    value = ponto.soma();
}